PORT=5000
CLIENT_ORIGIN=http://127.0.0.1:2002,http://localhost:2002

# MySQL order storage. These should match your MySQL Workbench local connection.
DB_ENABLED=true
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=masala_hub_app
DB_SSL=false

# Gmail sender for Nodemailer.
# Use a Google App Password, not your normal Gmail password.
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
EMAIL_FROM=Masala HUB <yourgmail@gmail.com>

# Admin dashboard access key. The browser never gets this automatically;
# admins type it on the Admin page.
ADMIN_ACCESS_KEY=change-this-admin-key

# Secret used to sign customer login tokens. Change this in production.
AUTH_SECRET=change-this-auth-secret

# Manual bank/UPI payment details shown on the checkout page.
# These are account details only. Do not put banking passwords, OTPs, or card PINs here.
PAYMENT_ACCOUNT_NAME=Your Restaurant Name
PAYMENT_BANK_NAME=Your Bank Name
PAYMENT_ACCOUNT_NUMBER=000000000000
PAYMENT_IFSC=ABCD0000000
PAYMENT_UPI_ID=9347491797@ibl

# Vite exposes only VITE_ variables to the browser checkout UI.
VITE_PAYMENT_ACCOUNT_NAME=Your Restaurant Name
VITE_PAYMENT_BANK_NAME=Your Bank Name
VITE_PAYMENT_ACCOUNT_NUMBER=000000000000
VITE_PAYMENT_IFSC=ABCD0000000
VITE_PAYMENT_UPI_ID=9347491797@ibl
VITE_PAYMENT_UPI_QR_IMAGE=/payment/upi-9347491797-ibl.svg

# Optional fallback for non-Gmail SMTP providers.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
